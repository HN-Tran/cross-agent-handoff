# Copy to .env — docker compose loads this automatically.
# Then:  docker compose up -d --build

# Host identity (file ownership + user: in compose)
UID=1000
GID=1000
HOME=/home/you
USER=you

# Optional: enable Wayland/X11 binds for --clipboard (requires docker-compose.clipboard.yml)
CAH_ENABLE_CLIPBOARD=0
COMPOSE_FILE=docker-compose.yml
# With clipboard:
# CAH_ENABLE_CLIPBOARD=1
# COMPOSE_FILE=docker-compose.yml:docker-compose.clipboard.yml
# XDG_RUNTIME_DIR=/run/user/1000
# WAYLAND_DISPLAY=wayland-0
# DISPLAY=:0

# Single-repo mode (optional): set WORKSPACE instead of mounting all of HOME.
# Uncomment and use docker-compose.workspace.yml if you only ever use one repo.
# WORKSPACE=/home/you/GitHub/your-repo
